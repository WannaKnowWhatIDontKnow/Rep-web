{
  "compilerOptions": {
    "target": "es5", // 오래된 브라우저 호환성을 위해 ES5 버전으로 컴파일
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false, // 100% TypeScript 프로젝트로 전환했으니 JS 파일을 허용하지 않음
    "skipLibCheck": true, // 설치된 라이브러리(node_modules)의 타입 검사는 건너뛰어 속도 향상
    "esModuleInterop": true, // CommonJS 모듈을 ES 모듈처럼 가져올 수 있게 함 (import React from 'react' 가능)
    "allowSyntheticDefaultImports": true, // 위와 동일
    "strict": true, // 모든 엄격한 타입 검사 옵션을 활성화 (가장 중요, TS의 장점을 극대화)
    "forceConsistentCasingInFileNames": true, // 파일 이름의 대소문자를 구분하도록 강제
    "noFallthroughCasesInSwitch": true, // switch문에서 break가 없는 경우를 에러로 처리
    "module": "esnext", // 최신 ES 모듈 시스템 사용
    "moduleResolution": "node", // 모듈 해석 전략을 Node.js 방식으로 설정
    "resolveJsonModule": true, // .json 파일을 모듈처럼 import 할 수 있도록 허용
    "isolatedModules": true, // 각 파일을 독립된 모듈로 처리하도록 강제 (CRA 기본값)
    "noEmit": true, // TS가 JS 파일을 생성하지 않음 (Babel이 이 역할을 대신함)
    "jsx": "react-jsx" // 최신 리액트의 JSX 변환 방식 사용
  },
  "include": [
    "src" // 타입 검사를 수행할 폴더 지정 (src 폴더 전체)
  ]
}
